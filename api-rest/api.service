[Unit]
Description=API REST de comandos del dron SAR
After=network-online.target mosquitto.service
Wants=network-online.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/drone-cloud-server
Environment=PYTHONUNBUFFERED=1
ExecStart=/home/ubuntu/env/bin/python /home/ubuntu/drone-cloud-server/api-rest/api.py
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target
