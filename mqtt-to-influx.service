[Unit]
Description=Puente MQTT -> InfluxDB (SAR)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu
Environment=PYTHONUNBUFFERED=1
ExecStart=/home/ubuntu/env/bin/python /home/ubuntu/mqtt_to_influx.py
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
